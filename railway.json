{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install",
    "watchPatterns": ["chatx/server/**"]
  },
  "deploy": {
    "startCommand": "node chatx/server/server.js",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/"
  }
}
